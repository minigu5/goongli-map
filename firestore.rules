rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /items/{itemId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && request.auth.token.email.matches('.*@ts\\.hs\\.kr');
    }

    match /decorations/{decoId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && request.auth.token.email.matches('.*@ts\\.hs\\.kr');
    }
  }
}
